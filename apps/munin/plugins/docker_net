#!/bin/bash

convert_bytes() {
    local input="$1"
    local val=0
    case "$input" in
        *PiB) val=$(echo "$input" | sed 's/PiB//' | awk '{printf "%.0f", $1 * 1125899906842624}') ;;
        *TiB) val=$(echo "$input" | sed 's/TiB//' | awk '{printf "%.0f", $1 * 1099511627776}') ;;
        *GiB) val=$(echo "$input" | sed 's/GiB//' | awk '{printf "%.0f", $1 * 1073741824}') ;;
        *MiB) val=$(echo "$input" | sed 's/MiB//' | awk '{printf "%.0f", $1 * 1048576}') ;;
        *KiB) val=$(echo "$input" | sed 's/KiB//' | awk '{printf "%.0f", $1 * 1024}') ;;
        *GB)  val=$(echo "$input" | sed 's/GB//'  | awk '{printf "%.0f", $1 * 1000000000}') ;;
        *MB)  val=$(echo "$input" | sed 's/MB//'  | awk '{printf "%.0f", $1 * 1000000}') ;;
        *kB)  val=$(echo "$input" | sed 's/kB//'  | awk '{printf "%.0f", $1 * 1000}') ;;
        *B)   val=$(echo "$input" | sed 's/B//'   | tr -d ' ') ;;
    esac
    echo "${val:-0}"
}

CONTAINERS=$(docker ps --format "{{.Names}}" 2>/dev/null | sort)

if [ "$1" = "config" ]; then
    echo "graph_title Docker Network I/O"
    echo "graph_vlabel bytes/sec"
    echo "graph_category docker"
    echo "graph_info Network I/O per container (bytes)"
    echo "graph_args --base 1000 -l 0"
    for c in $CONTAINERS; do
        name=$(echo "$c" | tr '.-' '_')
        echo "${name}_rx.label $c RX"
        echo "${name}_rx.type COUNTER"
        echo "${name}_rx.min 0"
        echo "${name}_tx.label $c TX"
        echo "${name}_tx.type COUNTER"
        echo "${name}_tx.min 0"
    done
    exit 0
fi

for c in $CONTAINERS; do
    name=$(echo "$c" | tr '.-' '_')
    net=$(docker stats --no-stream --format "{{.NetIO}}" "$c" 2>/dev/null)
    rx=$(echo "$net" | awk '{print $1}')
    tx=$(echo "$net" | awk '{print $3}')
    echo "${name}_rx.value $(convert_bytes "$rx")"
    echo "${name}_tx.value $(convert_bytes "$tx")"
done
